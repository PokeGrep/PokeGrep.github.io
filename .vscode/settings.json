{
  "files.associations": {
    "*.templ": "templ",
    "**/templates/**/*.go": "go",
    "**/templates/viewmodels/*.go": "go"
  },
  "[templ]": {
    "editor.defaultFormatter": "a-h.templ",
    "editor.formatOnSave": true,
    "editor.quickSuggestions": {
      "strings": "on"
    }
  },
  "emmet.includeLanguages": {
    "templ": "html"
  },
  "html-css-class-completion.includeGlobPattern": "**/*.{css,html,templ}",
  "html-css-class-completion.HTMLLanguages": [
    "templ"
  ]
}
